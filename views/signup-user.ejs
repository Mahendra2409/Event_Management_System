<%- include('partials/header') %>
<div class="login-page">
  <div class="login-branding">
    <div class="login-brand-logo"><span class="material-icons-outlined">shopping_bag</span><div><strong>NexCart</strong><br><small>Shop the Future</small></div></div>
    <div class="login-welcome">Join NexCart!</div>
    <div class="login-welcome-bar"></div>
    <div class="login-desc">Create your free account and start shopping from thousands of trusted sellers. Get exclusive deals, fast delivery, and easy returns.</div>
    <div class="login-features">
      <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">local_offer</span></div><div><h4>Exclusive Deals</h4><p>Members-only discounts</p></div></div>
      <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">favorite</span></div><div><h4>Wishlist</h4><p>Save items for later</p></div></div>
      <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">local_shipping</span></div><div><h4>Order Tracking</h4><p>Real-time delivery updates</p></div></div>
    </div>
  </div>
  <div class="login-form-panel">
    <div class="login-form-inner">
      <div class="login-form-header">
        <div class="login-icon"><span class="material-icons-outlined">person_add</span></div>
        <div><h1>Create Account</h1><p class="login-form-sub">Start shopping in minutes</p></div>
      </div>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <form action="/signup/user" method="POST" data-validate>
        <div class="form-group"><label>Full Name *</label><div class="input-icon-wrap"><span class="material-icons-outlined">person</span><input type="text" name="name" class="form-control" placeholder="John Doe" required data-label="Name"></div></div>
        <div class="form-group"><label>Email Address *</label><div class="input-icon-wrap"><span class="material-icons-outlined">mail</span><input type="email" name="email" class="form-control" placeholder="you@example.com" required data-label="Email"></div></div>
        <div class="form-group"><label>Password *</label><div class="input-icon-wrap"><span class="material-icons-outlined">lock</span><input type="password" name="password" class="form-control" placeholder="Min 6 characters" required data-label="Password" minlength="6"></div></div>
        <button type="submit" class="btn btn-primary btn-block btn-lg mt-2"><span class="material-icons-outlined">person_add</span> Create Account</button>
      </form>
      <div class="login-divider">or</div>
      <a href="/login" class="btn btn-outline btn-block">Already have an account? Login</a>
      <div class="login-footer">© 2025 NexCart. All rights reserved.</div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
