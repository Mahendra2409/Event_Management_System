<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header"><h1>Update <%= type.charAt(0).toUpperCase() + type.slice(1) %> Membership</h1><p>Look up and manage existing memberships</p></div>
      <div class="card" style="max-width:520px">
        <div class="card-header"><h2>Membership Lookup</h2></div>
        <div class="card-body">
          <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
          <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>

          <form action="/admin/membership/lookup/<%= type %>" method="POST" data-validate>
            <div class="form-group"><label>Membership Number *</label><input type="number" name="membership_id" class="form-control" placeholder="Enter Membership Number" required data-label="Membership Number" value="<%= membership ? membership.id : '' %>"></div>
            <button type="submit" class="btn btn-outline btn-block">Look Up Membership</button>
          </form>

          <% if (membership) { %>
          <hr style="margin:20px 0;border:1px solid var(--border-lt)">
          <h3 style="margin-bottom:12px;font-size:15px">Membership Details</h3>
          <div style="background:var(--muted);padding:14px;border-radius:var(--radius-sm);margin-bottom:16px;font-size:13px">
            <div class="d-flex justify-between mb-1"><span>ID:</span><strong>#<%= membership.id %></strong></div>
            <div class="d-flex justify-between mb-1"><span>Name:</span><strong><%= membership.member_name %></strong></div>
            <div class="d-flex justify-between mb-1"><span>Email:</span><strong><%= membership.member_email %></strong></div>
            <% if (membership.member_phone) { %><div class="d-flex justify-between mb-1"><span>Phone:</span><strong><%= membership.member_phone %></strong></div><% } %>
            <div class="d-flex justify-between mb-1"><span>Duration:</span><strong><%= membership.duration %></strong></div>
            <div class="d-flex justify-between mb-1"><span>Start Date:</span><strong><%= membership.start_date %></strong></div>
            <div class="d-flex justify-between mb-1"><span>End Date:</span><strong><%= membership.end_date %></strong></div>
            <div class="d-flex justify-between mb-1"><span>Status:</span><strong style="color:<%= membership.status === 'active' ? 'var(--success)' : 'var(--danger)' %>"><%= membership.status %></strong></div>
          </div>

          <form action="/admin/membership/update/<%= type %>" method="POST">
            <input type="hidden" name="membership_id" value="<%= membership.id %>">
            <input type="hidden" name="action" value="extend">
            <div class="form-group"><label>Extend By:</label>
              <div class="radio-group">
                <label class="radio-option"><input type="radio" name="extension_duration" value="6 months" checked><span>6 Months</span></label>
                <label class="radio-option"><input type="radio" name="extension_duration" value="1 year"><span>1 Year</span></label>
                <label class="radio-option"><input type="radio" name="extension_duration" value="2 years"><span>2 Years</span></label>
              </div>
            </div>
            <button type="submit" class="btn btn-success btn-block">Extend Membership</button>
          </form>

          <form action="/admin/membership/update/<%= type %>" method="POST" style="margin-top:8px">
            <input type="hidden" name="membership_id" value="<%= membership.id %>">
            <input type="hidden" name="action" value="cancel">
            <button type="submit" class="btn btn-danger btn-block" onclick="return confirm('Cancel this membership?')">Cancel Membership</button>
          </form>
          <% } %>
        </div>
      </div>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
