<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div class="page-header"><h1>Admin Dashboard</h1><p>Welcome, <%= user.name %>. Manage the system from here.</p></div>

      <div class="stat-cards">
        <div class="stat-card"><div class="stat-card-icon purple"><span class="material-icons-outlined">people</span></div><div><div class="stat-num"><%= userCount %></div><div class="stat-label">Total Users</div></div></div>
        <div class="stat-card"><div class="stat-card-icon blue"><span class="material-icons-outlined">storefront</span></div><div><div class="stat-num"><%= vendorCount %></div><div class="stat-label">Total Vendors</div></div></div>
        <div class="stat-card"><div class="stat-card-icon green"><span class="material-icons-outlined">card_membership</span></div><div><div class="stat-num"><%= membershipCount %></div><div class="stat-label">Memberships</div></div></div>
        <div class="stat-card"><div class="stat-card-icon orange"><span class="material-icons-outlined">receipt_long</span></div><div><div class="stat-num"><%= orderCount %></div><div class="stat-label">Total Orders</div></div></div>
      </div>

      <div class="dashboard-grid">
        <a href="/admin/maintain-user" class="dash-card">
          <div class="dash-card-icon"><span class="material-icons-outlined">people</span></div>
          <div><h3>Maintain User</h3><p>Manage users, memberships, add or update user accounts.</p></div>
          <span class="material-icons-outlined arrow">arrow_forward</span>
        </a>
        <a href="/admin/maintain-vendor" class="dash-card">
          <div class="dash-card-icon"><span class="material-icons-outlined">storefront</span></div>
          <div><h3>Maintain Vendor</h3><p>Manage vendors, memberships, add or update vendor accounts.</p></div>
          <span class="material-icons-outlined arrow">arrow_forward</span>
        </a>
      </div>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
