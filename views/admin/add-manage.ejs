<%- include('../partials/header') %>
<div class="app-layout"><%- include('../partials/sidebar-admin') %><div class="main-area"><%- include('../partials/topbar') %><div class="content">
  <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
  <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
  <div class="page-header"><h1>Add <%= type.charAt(0).toUpperCase() + type.slice(1) %></h1></div>
  <div class="card" style="max-width:560px"><div class="card-body">
    <form action="/admin/manage/add/<%= type %>" method="POST" data-validate>
      <div class="form-group"><label>Name *</label><div class="input-icon-wrap"><span class="material-icons-outlined">person</span><input type="text" name="name" class="form-control" required data-label="Name"></div></div>
      <div class="form-group"><label>Email *</label><div class="input-icon-wrap"><span class="material-icons-outlined">mail</span><input type="email" name="email" class="form-control" required data-label="Email"></div></div>
      <div class="form-group"><label>Password *</label><div class="input-icon-wrap"><span class="material-icons-outlined">lock</span><input type="password" name="password" class="form-control" required data-label="Password"></div></div>
      <% if (type === 'seller') { %>
      <div class="form-group"><label>Category *</label><select name="category" class="form-control" required><option value="">Select</option><option>Electronics</option><option>Fashion</option><option>Home & Kitchen</option><option>Beauty</option><option>Sports</option><option>Books</option></select></div>
      <% } %>
      <div class="btn-row mt-2"><a href="/admin/maintain-<%= type === 'seller' ? 'seller' : 'user' %>" class="btn btn-outline">Cancel</a><button type="submit" class="btn btn-primary">Add <%= type %></button></div>
    </form>
  </div></div>
</div><div class="app-footer">© 2025 NexCart.</div></div></div>
<%- include('../partials/footer') %>
