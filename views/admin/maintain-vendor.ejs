<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-admin') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <div class="page-header"><h1>Maintain Vendor</h1><p>Manage vendor memberships and accounts</p></div>

      <div class="maintenance-section">
        <h3><span class="material-icons-outlined">card_membership</span> Membership Management</h3>
        <div class="maintenance-actions">
          <a href="/admin/membership/add/vendor" class="btn btn-primary"><span class="material-icons-outlined" style="font-size:16px">add</span> Add Membership</a>
          <a href="/admin/membership/update/vendor" class="btn btn-outline"><span class="material-icons-outlined" style="font-size:16px">edit</span> Update Membership</a>
        </div>
      </div>
      <div class="maintenance-section">
        <h3><span class="material-icons-outlined">storefront</span> Vendor Management</h3>
        <div class="maintenance-actions">
          <a href="/admin/manage/add/vendor" class="btn btn-success"><span class="material-icons-outlined" style="font-size:16px">person_add</span> Add Vendor</a>
          <a href="/admin/manage/update/vendor" class="btn btn-warning"><span class="material-icons-outlined" style="font-size:16px">manage_accounts</span> Update / Delete Vendor</a>
        </div>
      </div>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
