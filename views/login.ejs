<%- include('partials/header') %>
<% const role = typeof loginRole !== 'undefined' ? loginRole : 'user'; %>
<div class="login-page">
  <div class="login-branding">
    <div class="login-brand-logo">
      <span class="material-icons-outlined">event</span>
      <div><strong>EMS</strong><br><small>Event Management System</small></div>
    </div>
    <div class="login-welcome" id="brandTitle">
      <%= role === 'admin' ? 'Welcome Admin!' : role === 'vendor' ? 'Welcome Vendor!' : 'Welcome User!' %>
    </div>
    <div class="login-welcome-bar"></div>
    <div class="login-desc" id="brandDesc">
      <% if (role === 'admin') { %>
        Log in to access the administrative dashboard and manage users, vendors, memberships, and system activities.
      <% } else if (role === 'vendor') { %>
        Login to your vendor account to manage your products, receive orders, update status and grow your business.
      <% } else { %>
        Login to your account to explore vendors, manage your cart, track orders and make your event unforgettable.
      <% } %>
    </div>
    <div class="login-features" id="brandFeatures">
      <% if (role === 'admin') { %>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">security</span></div><div><h4>Secure Access</h4><p>Your security is our priority</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">group</span></div><div><h4>User & Vendor Management</h4><p>Add, update and manage all users</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">card_membership</span></div><div><h4>Membership Management</h4><p>Manage membership plans and records</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">bar_chart</span></div><div><h4>Reports & Analytics</h4><p>View reports and system analytics</p></div></div>
      <% } else if (role === 'vendor') { %>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">inventory_2</span></div><div><h4>Manage Products</h4><p>Add, update and manage your products</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">shopping_cart</span></div><div><h4>Receive Orders</h4><p>View and manage incoming orders</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">analytics</span></div><div><h4>Track Performance</h4><p>Monitor your sales and performance</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">support_agent</span></div><div><h4>24/7 Support</h4><p>We are here to help you anytime</p></div></div>
      <% } else { %>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">storefront</span></div><div><h4>Explore Vendors</h4><p>Browse and choose from trusted vendors</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">shopping_cart</span></div><div><h4>Manage Cart</h4><p>Add products and place orders easily</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">local_shipping</span></div><div><h4>Track Orders</h4><p>Track your order status in real-time</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">group</span></div><div><h4>Guest List</h4><p>Manage your guest list seamlessly</p></div></div>
      <% } %>
    </div>
  </div>
  <div class="login-form-panel">
    <div class="login-form-inner">
      <div class="login-form-header">
        <div class="login-icon">
          <span class="material-icons-outlined"><%= role === 'admin' ? 'admin_panel_settings' : role === 'vendor' ? 'storefront' : 'person' %></span>
        </div>
        <div>
          <h1><%= role === 'admin' ? 'Admin Login' : role === 'vendor' ? 'Vendor Login' : 'User Login' %></h1>
          <p class="login-form-sub">Please enter your credentials to continue</p>
        </div>
      </div>

      <div class="login-divider"><span class="material-icons-outlined">lock</span></div>

      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>

      <div class="role-tabs">
        <a href="/login/admin" class="role-tab <%= role === 'admin' ? 'active' : '' %>">Admin</a>
        <a href="/login/user" class="role-tab <%= role === 'user' ? 'active' : '' %>">User</a>
        <a href="/login/vendor" class="role-tab <%= role === 'vendor' ? 'active' : '' %>">Vendor</a>
      </div>

      <form action="/login" method="POST" data-validate>
        <input type="hidden" name="role" id="role-input" value="<%= role %>">
        <div class="form-group">
          <label for="email">User ID / Email</label>
          <div class="input-icon-wrap">
            <span class="material-icons-outlined">mail</span>
            <input type="email" name="email" id="email" class="form-control" placeholder="Enter your email or user ID" required data-label="Email">
          </div>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <div class="input-icon-wrap">
            <span class="material-icons-outlined">lock</span>
            <input type="password" name="password" id="password" class="form-control" placeholder="Enter your password" required data-label="Password">
            <button type="button" class="toggle-password" onclick="togglePassword()"><span class="material-icons-outlined">visibility_off</span></button>
          </div>
        </div>
        <div class="login-remember">
          <label><input type="checkbox"> Remember me</label>
          <a href="#">Forgot Password?</a>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <span class="material-icons-outlined">login</span> Login
        </button>
      </form>

      <div class="login-divider">or</div>

      <% if (role === 'admin') { %>
        <a href="/" class="btn btn-outline btn-block"><span class="material-icons-outlined">arrow_back</span> Back to Home</a>
      <% } else if (role === 'vendor') { %>
        <a href="/signup/vendor" class="btn btn-outline btn-block"><span class="material-icons-outlined">person_add</span> New Vendor? Sign Up</a>
      <% } else { %>
        <a href="/signup/user" class="btn btn-outline btn-block"><span class="material-icons-outlined">person_add</span> New User? Sign Up</a>
      <% } %>

      <div class="login-footer">© 2025 Event Management System. All rights reserved.</div>
    </div>
  </div>
</div>
<script>
function togglePassword(){
  const p=document.getElementById('password');
  const t=p.type==='password'?'text':'password';
  p.type=t;
  p.nextElementSibling.querySelector('.material-icons-outlined').textContent=t==='password'?'visibility_off':'visibility';
}
</script>
<%- include('partials/footer') %>
