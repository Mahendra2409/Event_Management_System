<%- include('partials/header') %>
<% const role = typeof loginRole !== 'undefined' ? loginRole : 'user'; %>
<div class="login-page">
  <div class="login-branding">
    <div class="login-brand-logo">
      <span class="material-icons-outlined">shopping_bag</span>
      <div><strong>NexCart</strong><br><small>Shop the Future</small></div>
    </div>
    <div class="login-welcome" id="brandTitle">
      <%= role === 'admin' ? 'Welcome Admin!' : role === 'seller' ? 'Welcome Seller!' : 'Welcome Back!' %>
    </div>
    <div class="login-welcome-bar"></div>
    <div class="login-desc">
      <% if (role === 'admin') { %>
        Access the admin dashboard to manage users, sellers, categories, orders, and platform analytics.
      <% } else if (role === 'seller') { %>
        Login to manage your products, track orders, view analytics and grow your business on NexCart.
      <% } else { %>
        Login to discover amazing products, manage your cart, track orders and enjoy a seamless shopping experience.
      <% } %>
    </div>
    <div class="login-features">
      <% if (role === 'admin') { %>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">security</span></div><div><h4>Secure Access</h4><p>Enterprise-grade security</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">analytics</span></div><div><h4>Revenue Analytics</h4><p>Platform-wide insights</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">manage_accounts</span></div><div><h4>User Management</h4><p>Manage all platform users</p></div></div>
      <% } else if (role === 'seller') { %>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">inventory_2</span></div><div><h4>Product Management</h4><p>Add, edit and manage listings</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">trending_up</span></div><div><h4>Sales Analytics</h4><p>Track your performance</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">payments</span></div><div><h4>Instant Payouts</h4><p>Fast and secure payments</p></div></div>
      <% } else { %>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">local_shipping</span></div><div><h4>Fast Delivery</h4><p>Free shipping on orders ₹499+</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">verified</span></div><div><h4>Trusted Sellers</h4><p>Verified quality products</p></div></div>
        <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">autorenew</span></div><div><h4>Easy Returns</h4><p>30-day hassle-free returns</p></div></div>
      <% } %>
    </div>
  </div>
  <div class="login-form-panel">
    <div class="login-form-inner">
      <div class="login-form-header">
        <div class="login-icon">
          <span class="material-icons-outlined"><%= role === 'admin' ? 'admin_panel_settings' : role === 'seller' ? 'storefront' : 'person' %></span>
        </div>
        <div>
          <h1><%= role === 'admin' ? 'Admin Login' : role === 'seller' ? 'Seller Login' : 'Login' %></h1>
          <p class="login-form-sub">Enter your credentials to continue</p>
        </div>
      </div>
      <div class="login-divider"><span class="material-icons-outlined">lock</span></div>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div class="role-tabs">
        <a href="/login/user" class="role-tab <%= role === 'user' ? 'active' : '' %>">Customer</a>
        <a href="/login/seller" class="role-tab <%= role === 'seller' ? 'active' : '' %>">Seller</a>
        <a href="/login/admin" class="role-tab <%= role === 'admin' ? 'active' : '' %>">Admin</a>
      </div>
      <form action="/login" method="POST" data-validate>
        <input type="hidden" name="role" value="<%= role %>">
        <div class="form-group">
          <label for="email">Email Address</label>
          <div class="input-icon-wrap">
            <span class="material-icons-outlined">mail</span>
            <input type="email" name="email" id="email" class="form-control" placeholder="you@example.com" required data-label="Email">
          </div>
        </div>
        <div class="form-group">
          <label for="password">Password</label>
          <div class="input-icon-wrap">
            <span class="material-icons-outlined">lock</span>
            <input type="password" name="password" id="password" class="form-control" placeholder="Enter your password" required data-label="Password">
            <button type="button" class="toggle-password" onclick="togglePassword()"><span class="material-icons-outlined">visibility_off</span></button>
          </div>
        </div>
        <div class="login-remember">
          <label><input type="checkbox"> Remember me</label>
          <a href="#">Forgot Password?</a>
        </div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">
          <span class="material-icons-outlined">login</span> Login
        </button>
      </form>
      <div class="login-divider">or</div>
      <% if (role === 'admin') { %>
        <a href="/" class="btn btn-outline btn-block"><span class="material-icons-outlined">arrow_back</span> Back to Home</a>
      <% } else if (role === 'seller') { %>
        <a href="/signup/seller" class="btn btn-outline btn-block"><span class="material-icons-outlined">storefront</span> Start Selling on NexCart</a>
      <% } else { %>
        <a href="/signup/user" class="btn btn-outline btn-block"><span class="material-icons-outlined">person_add</span> Create an Account</a>
      <% } %>
      <div class="login-footer">© 2025 NexCart. All rights reserved.</div>
    </div>
  </div>
</div>
<script>
function togglePassword(){
  const p=document.getElementById('password');
  const t=p.type==='password'?'text':'password';
  p.type=t;
  p.nextElementSibling.querySelector('.material-icons-outlined').textContent=t==='password'?'visibility_off':'visibility';
}
</script>
<%- include('partials/footer') %>
