<%- include('partials/header') %>
<div class="main-container">
  <div class="auth-container">
    <div class="card">
      <div class="card-header">
        <h2 class="auth-title">Event Management System</h2>
        <p class="auth-subtitle">Sign in to your account</p>
      </div>
      <div class="card-body">
        <% if (locals.error) { %>
          <div class="alert alert-error">⚠️ <%= error %></div>
        <% } %>
        <% if (locals.success) { %>
          <div class="alert alert-success">✅ <%= success %></div>
        <% } %>

        <div class="role-tabs">
          <button type="button" class="role-tab active" data-role="admin">Admin</button>
          <button type="button" class="role-tab" data-role="user">User</button>
          <button type="button" class="role-tab" data-role="vendor">Vendor</button>
        </div>

        <form action="/login" method="POST" data-validate>
          <input type="hidden" name="role" id="role-input" value="admin">

          <div class="form-group">
            <label for="email">User Id (Email)</label>
            <input type="email" name="email" id="email" class="form-control" placeholder="Enter your email" required data-label="Email">
          </div>

          <div class="form-group">
            <label for="password">Password</label>
            <input type="password" name="password" id="password" class="form-control" placeholder="Enter your password" required data-label="Password">
          </div>

          <div class="btn-row">
            <a href="/" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Login</button>
          </div>
        </form>

        <div class="auth-footer">
          Don't have an account?
          <a href="/signup/user">Sign Up as User</a> |
          <a href="/signup/vendor">Sign Up as Vendor</a> |
          <a href="/signup/admin">Sign Up as Admin</a>
        </div>
      </div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
