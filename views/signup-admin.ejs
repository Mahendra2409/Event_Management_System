<%- include('partials/header') %>
<div class="login-page">
  <div class="login-branding">
    <div class="login-brand-logo"><span class="material-icons-outlined">event</span><div><strong>EMS</strong><br><small>Event Management System</small></div></div>
    <div class="login-welcome">Admin Registration</div>
    <div class="login-welcome-bar"></div>
    <div class="login-desc">Create an admin account to manage users, vendors, memberships, and system activities.</div>
    <div class="login-features">
      <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">admin_panel_settings</span></div><div><h4>Full Control</h4><p>Complete system management</p></div></div>
      <div class="login-feature"><div class="login-feature-icon"><span class="material-icons-outlined">security</span></div><div><h4>Secure Access</h4><p>Protected admin dashboard</p></div></div>
    </div>
  </div>
  <div class="login-form-panel">
    <div class="login-form-inner">
      <div class="login-form-header"><div class="login-icon"><span class="material-icons-outlined">admin_panel_settings</span></div><div><h1>Admin Sign Up</h1><p class="login-form-sub">Create admin account</p></div></div>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <form action="/signup/admin" method="POST" data-validate>
        <div class="form-group"><label>Name *</label><div class="input-icon-wrap"><span class="material-icons-outlined">person</span><input type="text" name="name" class="form-control" placeholder="Enter your name" required data-label="Name"></div></div>
        <div class="form-group"><label>Email *</label><div class="input-icon-wrap"><span class="material-icons-outlined">mail</span><input type="email" name="email" class="form-control" placeholder="Enter your email" required data-label="Email"></div></div>
        <div class="form-group"><label>Password *</label><div class="input-icon-wrap"><span class="material-icons-outlined">lock</span><input type="password" name="password" class="form-control" placeholder="Enter your password" required data-label="Password"></div></div>
        <button type="submit" class="btn btn-primary btn-block btn-lg">Sign Up</button>
      </form>
      <div class="login-divider">or</div>
      <a href="/login/admin" class="btn btn-outline btn-block">Already have an account? Login</a>
      <div class="login-footer">© 2025 Event Management System. All rights reserved.</div>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
