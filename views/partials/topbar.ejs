<header class="topbar">
  <div class="topbar-left">
    <button class="topbar-toggle" id="sidebarToggle" aria-label="Toggle sidebar">
      <span class="material-icons-outlined">menu</span>
    </button>
    <a href="/" class="topbar-brand">
      <span class="material-icons-outlined">shopping_bag</span>
      <strong>NexCart</strong>
    </a>
  </div>
  <div class="topbar-right">
    <a href="/user/wishlist" class="topbar-icon-btn" aria-label="Wishlist">
      <span class="material-icons-outlined">favorite_border</span>
      <% if (typeof wishlistCount !== 'undefined' && wishlistCount > 0) { %>
        <span class="badge"><%= wishlistCount %></span>
      <% } %>
    </a>
    <a href="/user/cart" class="topbar-icon-btn" aria-label="Cart">
      <span class="material-icons-outlined">shopping_cart</span>
      <% if (typeof cartCount !== 'undefined' && cartCount > 0) { %>
        <span class="badge"><%= cartCount %></span>
      <% } %>
    </a>
    <div class="topbar-user">
      <div class="topbar-avatar"><%= typeof user !== 'undefined' && user.name ? user.name.charAt(0).toUpperCase() : 'U' %></div>
      <div class="topbar-user-info">
        <div class="topbar-user-name"><%= typeof user !== 'undefined' ? user.name : 'User' %></div>
        <div class="topbar-user-role"><%= typeof user !== 'undefined' && user.role ? user.role.charAt(0).toUpperCase() + user.role.slice(1) : '' %></div>
      </div>
    </div>
  </div>
</header>
