<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-vendor') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <div class="page-header"><h1>Update Order Status</h1><p>Update the delivery status for order #<%= order.id %></p></div>

      <div class="card" style="max-width:600px">
        <div class="card-header"><h2>Order #<%= order.id %></h2></div>
        <div class="card-body">
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;font-size:13px">
            <div><strong>Customer:</strong> <%= order.name %></div>
            <div><strong>Email:</strong> <%= order.email %></div>
            <div><strong>Address:</strong> <%= order.address %></div>
            <div><strong>Current Status:</strong> <span class="status-badge <%= order.status === 'Out For Delivery' ? 'status-delivered' : order.status === 'Ready for Shipping' ? 'status-shipped' : 'status-pending' %>"><%= order.status %></span></div>
          </div>
          <form action="/vendor/update-order/<%= order.id %>" method="POST" data-validate>
            <div class="form-group"><label>Update Status *</label>
              <div class="radio-group">
                <label class="radio-option"><input type="radio" name="status" value="Received" <%= order.status === 'Received' ? 'checked' : '' %>><span>Received</span></label>
                <label class="radio-option"><input type="radio" name="status" value="Ready for Shipping" <%= order.status === 'Ready for Shipping' ? 'checked' : '' %>><span>Ready for Shipping</span></label>
                <label class="radio-option"><input type="radio" name="status" value="Out For Delivery" <%= order.status === 'Out For Delivery' ? 'checked' : '' %>><span>Out For Delivery</span></label>
              </div>
            </div>
            <div class="btn-row"><a href="/vendor/product-status" class="btn btn-secondary">Cancel</a><button type="submit" class="btn btn-primary">Update Status</button></div>
          </form>
        </div>
      </div>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
