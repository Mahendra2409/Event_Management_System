<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-vendor') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
        <div class="page-header" style="margin-bottom:0"><h1>Add Product</h1><p>List a new product on NexCart</p></div>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:24px">
        <div class="card"><div class="card-header"><h2>Product Details</h2></div><div class="card-body">
          <form action="/seller/add-item" method="POST" enctype="multipart/form-data" data-validate>
            <div class="form-group"><label>Product Name *</label><input type="text" name="name" class="form-control" placeholder="e.g. Wireless Headphones" required data-label="Product Name"></div>
            <div class="grid-2">
              <div class="form-group"><label>Price (₹) *</label><input type="number" name="price" class="form-control" placeholder="999.00" step="0.01" required data-label="Price"></div>
              <div class="form-group"><label>Discount Price (₹)</label><input type="number" name="discount_price" class="form-control" placeholder="799.00" step="0.01"></div>
            </div>
            <div class="grid-2">
              <div class="form-group"><label>Category</label><select name="category_id" class="form-control"><option value="">Select Category</option><% if (typeof categories !== 'undefined') { categories.forEach(c => { %><option value="<%= c.id %>"><%= c.name %></option><% }) } %></select></div>
              <div class="form-group"><label>Stock Quantity</label><input type="number" name="stock" class="form-control" placeholder="100" value="100"></div>
            </div>
            <div class="form-group"><label>Description</label><textarea name="description" class="form-control" rows="3" placeholder="Describe your product..."></textarea></div>
            <div class="form-group"><label>Product Image</label><input type="file" name="image" class="form-control" accept="image/*"></div>
            <button type="submit" class="btn btn-primary btn-lg btn-block mt-2"><span class="material-icons-outlined" style="font-size:18px">add_box</span> Add Product</button>
          </form>
        </div></div>
        <div>
          <div class="section-card"><h3>Your Products (<%= products.length %>)</h3>
            <% if (products.length > 0) { products.forEach(p => { %>
            <div style="display:flex;align-items:center;gap:12px;padding:10px 0;border-bottom:1px solid var(--border-lt)">
              <div style="width:44px;height:44px;border-radius:8px;overflow:hidden;background:var(--muted);flex-shrink:0"><img src="/uploads/<%= p.image %>" style="width:100%;height:100%;object-fit:cover" onerror="this.src=''"></div>
              <div style="flex:1;min-width:0"><strong style="font-size:13px;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= p.name %></strong><small style="color:var(--text-tri)">₹<%= p.price.toFixed(2) %></small></div>
              <a href="/seller/update-item/<%= p.id %>" class="btn btn-sm btn-outline">Edit</a>
              <form action="/seller/delete-item/<%= p.id %>" method="POST" style="display:inline"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete?')"><span class="material-icons-outlined" style="font-size:14px">delete</span></button></form>
            </div>
            <% }) } else { %><p style="color:var(--text-tri);font-size:13px">No products yet.</p><% } %>
          </div>
        </div>
      </div>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
