<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-vendor') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <div class="page-header"><h1>Add New Item</h1><p>Add a new product or service to your catalog</p></div>

      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="card"><div class="card-header"><h2>Product Details</h2></div><div class="card-body">
          <form action="/vendor/add-item" method="POST" enctype="multipart/form-data" data-validate>
            <div class="form-group"><label>Product Name *</label><input type="text" name="name" class="form-control" placeholder="Enter product name" required data-label="Product Name"></div>
            <div class="form-group"><label>Price *</label><input type="number" name="price" class="form-control" placeholder="Enter price" step="0.01" required data-label="Price"></div>
            <div class="form-group"><label>Product Image</label><input type="file" name="image" class="form-control" accept="image/*"></div>
            <button type="submit" class="btn btn-primary btn-block">Add Product</button>
          </form>
        </div></div>
        <div class="card"><div class="card-header"><h2>Your Products (<%= products.length %>)</h2></div><div class="card-body" style="max-height:400px;overflow-y:auto">
          <% if (products.length > 0) { products.forEach(p => { %>
            <div style="display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--border-lt)">
              <div style="width:40px;height:40px;border-radius:8px;overflow:hidden;background:var(--muted)"><img src="/uploads/<%= p.image %>" style="width:100%;height:100%;object-fit:cover" onerror="this.src=''"></div>
              <div style="flex:1"><strong style="font-size:13px"><%= p.name %></strong><br><small style="color:var(--primary)">₹<%= p.price.toFixed(2) %></small></div>
              <a href="/vendor/update-item/<%= p.id %>" class="btn btn-sm btn-outline">Edit</a>
              <form action="/vendor/delete-item/<%= p.id %>" method="POST" style="display:inline"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this product?')"><span class="material-icons-outlined" style="font-size:14px">delete</span></button></form>
            </div>
          <% }) } else { %><p style="color:var(--text-tri);font-size:13px">No products yet.</p><% } %>
        </div></div>
      </div>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
