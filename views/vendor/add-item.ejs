<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> Vendor</div>
  <div class="navbar-links">
    <a href="/vendor" class="nav-link">Home</a>
    <a href="/vendor/product-status" class="nav-link">Product Status</a>
    <a href="/vendor/request-items" class="nav-link">Request Items</a>
    <a href="/vendor/items" class="nav-link">View Products</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <% if (locals.success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <% if (locals.error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="page-header">
    <h1>Welcome, <%= user.name %></h1>
    <p>Add new products and manage your catalog</p>
  </div>

  <div style="display:grid;grid-template-columns:1fr 1.5fr;gap:2rem;">
    <!-- Add Product Form -->
    <div class="card">
      <div class="card-header"><h2>Add Product</h2></div>
      <div class="card-body">
        <form action="/vendor/add-item" method="POST" enctype="multipart/form-data" data-validate>
          <div class="form-group">
            <label for="name">Product Name *</label>
            <input type="text" name="name" id="name" class="form-control" placeholder="Enter product name" required data-label="Product Name">
          </div>
          <div class="form-group">
            <label for="price">Product Price (₹) *</label>
            <input type="number" name="price" id="price" class="form-control" placeholder="Enter price" step="0.01" min="0" required data-label="Product Price">
          </div>
          <div class="form-group">
            <label for="image">Product Image</label>
            <input type="file" name="image" id="image" class="form-control" accept="image/*">
          </div>
          <button type="submit" class="btn btn-primary btn-block">Add The Product</button>
        </form>
      </div>
    </div>

    <!-- Existing Products -->
    <div class="card">
      <div class="card-header"><h2>Your Products</h2></div>
      <div class="card-body" style="padding:0;">
        <% if (products && products.length > 0) { %>
        <div class="table-container">
          <table>
            <thead>
              <tr>
                <th>Image</th>
                <th>Product Name</th>
                <th>Price</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% products.forEach(p => { %>
              <tr>
                <td><img src="/uploads/<%= p.image %>" alt="<%= p.name %>" style="width:50px;height:50px;object-fit:cover;border-radius:6px;" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI1MCIgaGVpZ2h0PSI1MCIgZmlsbD0iI2NjYyI+PHJlY3Qgd2lkdGg9IjUwIiBoZWlnaHQ9IjUwIiBmaWxsPSIjZWVlIi8+PHRleHQgeD0iNTAlIiB5PSI1MCUiIGRvbWluYW50LWJhc2VsaW5lPSJtaWRkbGUiIHRleHQtYW5jaG9yPSJtaWRkbGUiIGZvbnQtc2l6ZT0iMTIiPjwvdGV4dD48L3N2Zz4='"></td>
                <td><%= p.name %></td>
                <td>₹<%= p.price.toFixed(2) %></td>
                <td>
                  <div style="display:flex;gap:0.4rem;">
                    <a href="/vendor/update-item/<%= p.id %>" class="btn btn-sm btn-warning">Update</a>
                    <form action="/vendor/delete-item/<%= p.id %>" method="POST" style="display:inline;">
                      <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this product?')">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
        <% } else { %>
          <div class="text-center" style="padding:2rem;color:var(--text-tertiary);">
            <p>No products yet. Add your first product!</p>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
