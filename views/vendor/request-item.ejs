<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> Vendor</div>
  <div class="navbar-links">
    <a href="/vendor" class="nav-link">Home</a>
    <a href="/vendor/request-items" class="nav-link active">Request Items</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <div class="page-header">
    <h1>Request Items</h1>
    <p>User requests for products</p>
  </div>
  <% if (requests && requests.length > 0) { %>
  <div class="products-grid">
    <% requests.forEach(r => { %>
    <div class="product-card">
      <div class="product-info" style="padding:1.5rem;">
        <div class="product-name"><%= r.product_name %></div>
        <p style="color:var(--text-tertiary);font-size:0.85rem;margin:0.3rem 0;">From: <%= r.user_name %></p>
        <p style="color:var(--text-tertiary);font-size:0.85rem;margin-bottom:0.8rem;"><%= r.request_details || 'No details' %></p>
        <span class="status-badge status-received"><%= r.status %></span>
      </div>
    </div>
    <% }) %>
  </div>
  <% } else { %>
  <div class="card card-body text-center">
    <p style="color:var(--text-tertiary);">No user requests yet.</p>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
