<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-vendor') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header"><h1>Request Items</h1><p>View requests from users for new items</p></div>
      <% if (requests && requests.length > 0) { %>
      <div class="table-container">
        <table>
          <thead><tr><th>#</th><th>User</th><th>Product Requested</th><th>Details</th><th>Date</th></tr></thead>
          <tbody>
          <% requests.forEach((r, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <td><%= r.user_name %></td>
              <td><strong><%= r.product_name %></strong></td>
              <td><%= r.request_details || '-' %></td>
              <td><%= new Date(r.created_at).toLocaleDateString() %></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="card card-body text-center"><p style="color:var(--text-tri)">No item requests yet.</p></div>
      <% } %>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
