<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-vendor') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div class="page-header"><h1>Seller Dashboard</h1><p>Manage your products, track orders and grow your business.</p></div>
      <div class="stat-cards">
        <div class="stat-card"><div class="stat-card-icon purple"><span class="material-icons-outlined">inventory_2</span></div><div><div class="stat-num"><%= productCount %></div><div class="stat-label">Products</div></div></div>
        <div class="stat-card"><div class="stat-card-icon blue"><span class="material-icons-outlined">shopping_cart</span></div><div><div class="stat-num"><%= totalOrders %></div><div class="stat-label">Orders</div></div></div>
        <div class="stat-card"><div class="stat-card-icon green"><span class="material-icons-outlined">check_circle</span></div><div><div class="stat-num"><%= completedOrders %></div><div class="stat-label">Completed</div></div></div>
        <div class="stat-card"><div class="stat-card-icon orange"><span class="material-icons-outlined">payments</span></div><div><div class="stat-num">₹<%= (totalEarnings || 0).toFixed(0) %></div><div class="stat-label">Earnings</div></div></div>
      </div>
      <div style="display:grid;grid-template-columns:2fr 1fr;gap:16px">
        <div class="section-card">
          <h3>Recent Products <a href="/seller/items">View All</a></h3>
          <% if (products && products.length > 0) { %>
          <div class="table-container" style="border:none"><table><thead><tr><th>Image</th><th>Product</th><th>Price</th><th>Action</th></tr></thead><tbody>
            <% products.forEach(p => { %><tr><td><div style="width:48px;height:48px;border-radius:8px;overflow:hidden;background:var(--muted)"><img src="/uploads/<%= p.image %>" style="width:100%;height:100%;object-fit:cover" onerror="this.src=''"></div></td><td><strong><%= p.name %></strong></td><td>₹<%= p.price.toFixed(2) %></td><td><a href="/seller/update-item/<%= p.id %>" class="btn btn-sm btn-outline">Edit</a></td></tr><% }) %>
          </tbody></table></div>
          <% } else { %><p style="color:var(--text-tri);font-size:13px">No products yet. <a href="/seller/add-item" style="color:var(--primary)">Add your first product</a>.</p><% } %>
        </div>
        <div class="section-card">
          <h3>Quick Actions</h3>
          <div class="quick-actions">
            <a href="/seller/add-item" class="quick-action"><span class="material-icons-outlined">add_box</span><span>Add Product</span><span class="material-icons-outlined arrow">chevron_right</span></a>
            <a href="/seller/transactions" class="quick-action"><span class="material-icons-outlined">payments</span><span>Transactions</span><span class="material-icons-outlined arrow">chevron_right</span></a>
            <a href="/seller/product-status" class="quick-action"><span class="material-icons-outlined">local_shipping</span><span>Manage Orders</span><span class="material-icons-outlined arrow">chevron_right</span></a>
            <a href="/seller/inquiries" class="quick-action"><span class="material-icons-outlined">question_answer</span><span>Inquiries</span><span class="material-icons-outlined arrow">chevron_right</span></a>
          </div>
        </div>
      </div>
      <% if (recentTransactions && recentTransactions.length > 0) { %>
      <div class="section-card mt-3">
        <h3>Recent Transactions <a href="/seller/transactions">View All</a></h3>
        <div class="table-container" style="border:none"><table><thead><tr><th>Order</th><th>Customer</th><th>Item</th><th>Amount</th><th>Status</th><th>Date</th></tr></thead><tbody>
          <% recentTransactions.forEach(t => { %><tr><td>#<%= t.id %></td><td><%= t.user_name %></td><td><%= t.product_name %></td><td>₹<%= (t.item_price * t.quantity).toFixed(2) %></td><td><span class="status-badge <%= t.status === 'Delivered' ? 'status-delivered' : t.status === 'Shipped' ? 'status-shipped' : 'status-processing' %>"><%= t.status %></span></td><td><%= new Date(t.created_at).toLocaleDateString() %></td></tr><% }) %>
        </tbody></table></div>
      </div>
      <% } %>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
