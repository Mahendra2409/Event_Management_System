<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> Vendor</div>
  <div class="navbar-links">
    <a href="/vendor" class="nav-link">Home</a>
    <a href="/vendor/add-item" class="nav-link">Back</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <div class="auth-container">
    <div class="card">
      <div class="card-header"><h2>Update Product</h2></div>
      <div class="card-body">
        <% if (locals.error) { %>
          <div class="alert alert-error">⚠️ <%= error %></div>
        <% } %>
        <form action="/vendor/update-item/<%= product.id %>" method="POST" enctype="multipart/form-data" data-validate>
          <div class="form-group">
            <label for="name">Product Name *</label>
            <input type="text" name="name" id="name" class="form-control" value="<%= product.name %>" required data-label="Product Name">
          </div>
          <div class="form-group">
            <label for="price">Product Price (₹) *</label>
            <input type="number" name="price" id="price" class="form-control" value="<%= product.price %>" step="0.01" min="0" required data-label="Product Price">
          </div>
          <div class="form-group">
            <label>Current Image</label>
            <div style="margin:0.5rem 0;">
              <img src="/uploads/<%= product.image %>" alt="<%= product.name %>" style="width:100px;height:100px;object-fit:cover;border-radius:8px;" onerror="this.style.display='none'">
            </div>
            <label for="image">Change Image</label>
            <input type="file" name="image" id="image" class="form-control" accept="image/*">
          </div>
          <div class="btn-row">
            <a href="/vendor/add-item" class="btn btn-secondary">Cancel</a>
            <button type="submit" class="btn btn-primary">Update Product</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
