<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-vendor') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <div class="page-header"><h1>Update Product</h1><p>Edit product details</p></div>
      <div class="card" style="max-width:500px">
        <div class="card-header"><h2><%= product.name %></h2></div>
        <div class="card-body">
          <div style="text-align:center;margin-bottom:16px"><div style="width:120px;height:120px;border-radius:12px;overflow:hidden;background:var(--muted);margin:0 auto"><img src="/uploads/<%= product.image %>" style="width:100%;height:100%;object-fit:cover" onerror="this.src=''"></div></div>
          <form action="/vendor/update-item/<%= product.id %>" method="POST" enctype="multipart/form-data" data-validate>
            <div class="form-group"><label>Product Name *</label><input type="text" name="name" class="form-control" value="<%= product.name %>" required data-label="Product Name"></div>
            <div class="form-group"><label>Price *</label><input type="number" name="price" class="form-control" value="<%= product.price %>" step="0.01" required data-label="Price"></div>
            <div class="form-group"><label>New Image</label><input type="file" name="image" class="form-control" accept="image/*"></div>
            <div class="btn-row"><a href="/vendor/add-item" class="btn btn-secondary">Cancel</a><button type="submit" class="btn btn-primary">Update Product</button></div>
          </form>
        </div>
      </div>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
