<%- include('../partials/header') %>
<div class="payment-page">
  <div class="payment-card">
    <div class="payment-header">
      <span class="material-icons-outlined" style="font-size:40px">lock</span>
      <h2>Processing Payment</h2>
      <p>Please wait while we process your transaction securely</p>
    </div>
    <div class="payment-body">
      <div class="payment-amount">₹<%= totalAmount.toFixed(2) %></div>
      <p style="color:var(--text-tri);font-size:13px;margin-bottom:4px"><%= name %> • <%= itemCount %> item<%= itemCount > 1 ? 's' : '' %></p>
      <p style="font-size:13px;font-weight:600;color:var(--text-sec)"><%= payment_method %></p>
      <div class="payment-spinner" id="paymentSpinner"></div>
      <p style="font-size:13px;color:var(--text-sec)" id="statusText">Connecting to payment gateway...</p>
      <div class="payment-steps">
        <div class="payment-step active" id="step1"><div class="step-icon"><span class="material-icons-outlined" style="font-size:16px">link</span></div><span>Connecting to gateway</span></div>
        <div class="payment-step" id="step2"><div class="step-icon"><span class="material-icons-outlined" style="font-size:16px">verified_user</span></div><span>Verifying details</span></div>
        <div class="payment-step" id="step3"><div class="step-icon"><span class="material-icons-outlined" style="font-size:16px">credit_card</span></div><span>Processing transaction</span></div>
        <div class="payment-step" id="step4"><div class="step-icon"><span class="material-icons-outlined" style="font-size:16px">check_circle</span></div><span>Confirming order</span></div>
      </div>
      <form action="/user/payment/confirm" method="POST" id="confirmForm" style="display:none">
        <button type="submit" class="btn btn-primary btn-block btn-lg" id="confirmBtn" disabled>
          <span class="material-icons-outlined" style="font-size:18px">check_circle</span> Payment Successful — View Order
        </button>
      </form>
      <div style="margin-top:12px"><a href="/user/cart" id="cancelLink" class="btn btn-secondary btn-block"><span class="material-icons-outlined" style="font-size:16px">arrow_back</span> Cancel</a></div>
      <div class="checkout-security mt-2"><span class="material-icons-outlined" style="font-size:14px">shield</span> 256-bit SSL • PCI DSS Compliant</div>
    </div>
  </div>
</div>
<script>
(function(){const s=['step1','step2','step3','step4'],m=['Connecting to payment gateway...','Verifying payment details...','Processing transaction...','Payment successful!'];let c=0;function a(){if(c>0){const p=document.getElementById(s[c-1]);p.classList.remove('active');p.classList.add('done');p.querySelector('.step-icon').innerHTML='<span class="material-icons-outlined" style="font-size:16px">check</span>';}if(c<s.length){document.getElementById(s[c]).classList.add('active');document.getElementById('statusText').textContent=m[c];c++;if(c<s.length){setTimeout(a,1200+Math.random()*800);}else{setTimeout(()=>{const l=document.getElementById(s[c-1]);l.classList.remove('active');l.classList.add('done');l.querySelector('.step-icon').innerHTML='<span class="material-icons-outlined" style="font-size:16px">check</span>';document.getElementById('paymentSpinner').style.display='none';document.getElementById('statusText').innerHTML='<span style="color:var(--success);font-weight:600">✅ Payment Successful!</span>';document.getElementById('confirmForm').style.display='block';document.getElementById('confirmBtn').disabled=false;document.getElementById('cancelLink').style.display='none';},800);}}}setTimeout(a,600);})();
</script>
<%- include('../partials/footer') %>
