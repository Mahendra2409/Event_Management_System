<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> User</div>
  <div class="navbar-links">
    <a href="/user" class="nav-link">Home</a>
    <a href="/user/vendors" class="nav-link">Vendor</a>
    <a href="/user/cart" class="nav-link">Cart</a>
    <a href="/user/guest-list" class="nav-link">Guest List</a>
    <a href="/user/order-status" class="nav-link active">Order Status</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <div class="page-header">
    <h1>User Order Status</h1>
    <p>Track your orders</p>
  </div>

  <% if (orders && orders.length > 0) { %>
  <div class="table-container card">
    <table>
      <thead>
        <tr>
          <th>Order #</th>
          <th>Name</th>
          <th>E-mail</th>
          <th>Address</th>
          <th>Status</th>
          <th>Date</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(o => { %>
        <tr>
          <td>#<%= o.id %></td>
          <td><%= o.name %></td>
          <td><%= o.email %></td>
          <td><%= o.address %>, <%= o.city %>, <%= o.state %> - <%= o.pincode %></td>
          <td>
            <span style="padding:0.3rem 0.8rem;border-radius:20px;font-size:0.8rem;font-weight:600;
              background:<%= o.status === 'Received' ? 'rgba(255,209,102,0.2);color:#e5a100' : o.status === 'Ready for Shipping' ? 'rgba(72,149,239,0.2);color:#4895ef' : o.status === 'Out For Delivery' ? 'rgba(6,214,160,0.2);color:#06d6a0' : 'rgba(239,71,111,0.2);color:#ef476f' %>;">
              <%= o.status %>
            </span>
          </td>
          <td><%= new Date(o.created_at).toLocaleDateString() %></td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="card card-body text-center">
    <p style="color:var(--grey-600);margin-bottom:1rem;">No orders yet.</p>
    <a href="/user/vendors" class="btn btn-primary">Start Shopping</a>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
