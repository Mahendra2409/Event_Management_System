<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header"><h1>My Orders</h1><p>Track your order status</p></div>
      <div class="stat-cards">
        <div class="stat-card"><div class="stat-card-icon purple"><span class="material-icons-outlined">receipt_long</span></div><div><div class="stat-num"><%= stats.total %></div><div class="stat-label">Total</div></div></div>
        <div class="stat-card"><div class="stat-card-icon orange"><span class="material-icons-outlined">hourglass_top</span></div><div><div class="stat-num"><%= stats.processing %></div><div class="stat-label">Processing</div></div></div>
        <div class="stat-card"><div class="stat-card-icon blue"><span class="material-icons-outlined">local_shipping</span></div><div><div class="stat-num"><%= stats.shipped %></div><div class="stat-label">Shipped</div></div></div>
        <div class="stat-card"><div class="stat-card-icon green"><span class="material-icons-outlined">check_circle</span></div><div><div class="stat-num"><%= stats.delivered %></div><div class="stat-label">Delivered</div></div></div>
      </div>
      <% if (orders && orders.length > 0) { %>
      <div class="table-container">
        <table><thead><tr><th>Order</th><th>Amount</th><th>Payment</th><th>Status</th><th>Date</th></tr></thead>
        <tbody><% orders.forEach(o => { %>
          <tr>
            <td><strong>#<%= o.id %></strong><br><small style="color:var(--text-tri)"><%= o.name %></small></td>
            <td style="font-weight:600">₹<%= o.total_amount ? o.total_amount.toFixed(2) : '0.00' %></td>
            <td><%= o.payment_method %></td>
            <td><span class="status-badge <%= o.status === 'Delivered' ? 'status-delivered' : o.status === 'Shipped' ? 'status-shipped' : o.status === 'Cancelled' ? 'status-cancelled' : 'status-processing' %>"><%= o.status %></span></td>
            <td><%= new Date(o.created_at).toLocaleDateString() %></td>
          </tr>
        <% }) %></tbody></table>
      </div>
      <% } else { %><div class="card card-body text-center" style="padding:48px"><span class="material-icons-outlined" style="font-size:48px;color:var(--text-tri)">shopping_bag</span><h3 style="margin:12px 0 4px">No orders yet</h3><a href="/user/view-products" class="btn btn-primary mt-2">Start Shopping</a></div><% } %>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
