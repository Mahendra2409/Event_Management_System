<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div class="page-header"><h1>My Wishlist</h1><p>Items you saved for later</p></div>
      <% if (items && items.length > 0) { %>
      <div class="products-grid">
        <% items.forEach(w => { %>
        <div class="product-card">
          <div class="product-img">
            <img src="/uploads/<%= w.image %>" alt="<%= w.name %>" onerror="this.style.display='none'">
            <form action="/user/wishlist/remove/<%= w.id %>" method="POST" style="display:inline"><button type="submit" class="product-wishlist-btn active"><span class="material-icons-outlined">favorite</span></button></form>
          </div>
          <div class="product-body">
            <a href="/user/product/<%= w.product_id %>"><h4><%= w.name %></h4></a>
            <small><%= w.seller_name %></small>
            <% if (w.rating > 0) { %><div class="stars" style="margin-top:4px"><% for(let i=1;i<=5;i++){%><span class="material-icons-outlined<%= i > Math.round(w.rating) ? ' empty' : '' %>">star</span><%}%></div><% } %>
            <div class="product-footer">
              <span class="product-price">₹<%= (w.discount_price || w.price).toFixed(2) %><% if (w.discount_price) { %><span class="original">₹<%= w.price.toFixed(2) %></span><% } %></span>
              <form action="/user/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= w.product_id %>"><input type="hidden" name="quantity" value="1"><button type="submit" class="btn btn-sm btn-primary"><span class="material-icons-outlined" style="font-size:14px">add_shopping_cart</span></button></form>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="card card-body text-center" style="padding:48px">
        <span class="material-icons-outlined" style="font-size:48px;color:var(--text-tri)">favorite_border</span>
        <h3 style="margin:12px 0 4px">Your wishlist is empty</h3>
        <p style="color:var(--text-tri);margin-bottom:16px">Browse products and save items you love.</p>
        <a href="/user/view-products" class="btn btn-primary">Browse Products</a>
      </div>
      <% } %>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
