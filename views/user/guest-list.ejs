<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> User</div>
  <div class="navbar-links">
    <a href="/user" class="nav-link">Home</a>
    <a href="/user/vendors" class="nav-link">Vendor</a>
    <a href="/user/cart" class="nav-link">Cart</a>
    <a href="/user/guest-list" class="nav-link active">Guest List</a>
    <a href="/user/order-status" class="nav-link">Order Status</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <% if (locals.success) { %>
    <div class="alert alert-success"><%= success %></div>
  <% } %>
  <% if (locals.error) { %>
    <div class="alert alert-error"><%= error %></div>
  <% } %>

  <div class="page-header">
    <h1>Guest List</h1>
    <p>Manage your event guests</p>
  </div>

  <!-- Add Guest Form -->
  <div class="card mb-3">
    <div class="card-header"><h2>Add Guest</h2></div>
    <div class="card-body">
      <form action="/user/guest-list/add" method="POST" data-validate>
        <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
          <div class="form-group">
            <label for="guest_name">Guest Name *</label>
            <input type="text" name="guest_name" id="guest_name" class="form-control" placeholder="Guest name" required data-label="Guest Name">
          </div>
          <div class="form-group">
            <label for="guest_email">Guest Email *</label>
            <input type="email" name="guest_email" id="guest_email" class="form-control" placeholder="Guest email" required data-label="Guest Email">
          </div>
          <div class="form-group">
            <label for="guest_phone">Guest Phone</label>
            <input type="tel" name="guest_phone" id="guest_phone" class="form-control" placeholder="Phone (optional)">
          </div>
          <div class="form-group">
            <label for="event_info">Event Info</label>
            <input type="text" name="event_info" id="event_info" class="form-control" placeholder="Event details (optional)">
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Add Guest</button>
      </form>
    </div>
  </div>

  <!-- Guest List Table -->
  <% if (guests && guests.length > 0) { %>
  <div class="table-container card">
    <table>
      <thead>
        <tr>
          <th>Name</th>
          <th>Email</th>
          <th>Phone</th>
          <th>Event</th>
          <th>Update</th>
          <th>Delete</th>
        </tr>
      </thead>
      <tbody>
        <% guests.forEach(g => { %>
        <tr>
          <form action="/user/guest-list/update/<%= g.id %>" method="POST">
          <td><input type="text" name="guest_name" value="<%= g.guest_name %>" class="form-control" style="padding:0.4rem;font-size:0.85rem;" required></td>
          <td><input type="email" name="guest_email" value="<%= g.guest_email %>" class="form-control" style="padding:0.4rem;font-size:0.85rem;" required></td>
          <td><input type="tel" name="guest_phone" value="<%= g.guest_phone || '' %>" class="form-control" style="padding:0.4rem;font-size:0.85rem;"></td>
          <td><input type="text" name="event_info" value="<%= g.event_info || '' %>" class="form-control" style="padding:0.4rem;font-size:0.85rem;"></td>
          <td><button type="submit" class="btn btn-sm btn-primary">Update</button></td>
          </form>
          <td>
            <form action="/user/guest-list/delete/<%= g.id %>" method="POST">
              <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Remove this guest?')">Delete</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
  <% } else { %>
  <div class="card card-body text-center">
    <p style="color:var(--text-tertiary);">No guests added yet.</p>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
