<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <div class="page-header"><h1>Guest List</h1><p>Manage your guest list for the event</p></div>

      <div class="card mb-3">
        <div class="card-header"><h2>Add Guest</h2></div>
        <div class="card-body">
          <form action="/user/guest-list/add" method="POST" data-validate>
            <div class="grid-2">
              <div class="form-group"><label>Guest Name *</label><input type="text" name="guest_name" class="form-control" placeholder="Enter guest name" required data-label="Guest Name"></div>
              <div class="form-group"><label>Email *</label><input type="email" name="guest_email" class="form-control" placeholder="Enter guest email" required data-label="Email"></div>
            </div>
            <div class="grid-2">
              <div class="form-group"><label>Phone</label><input type="text" name="guest_phone" class="form-control" placeholder="Phone number"></div>
              <div class="form-group"><label>Event Info</label><input type="text" name="event_info" class="form-control" placeholder="Event details"></div>
            </div>
            <button type="submit" class="btn btn-primary">Add Guest</button>
          </form>
        </div>
      </div>

      <% if (guests && guests.length > 0) { %>
      <div class="table-container">
        <table>
          <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Phone</th><th>Event</th><th>Actions</th></tr></thead>
          <tbody>
          <% guests.forEach((g, i) => { %>
            <tr>
              <td><%= i + 1 %></td>
              <form action="/user/guest-list/update/<%= g.id %>" method="POST">
              <td><input type="text" name="guest_name" value="<%= g.guest_name %>" class="form-control" style="min-width:120px"></td>
              <td><input type="email" name="guest_email" value="<%= g.guest_email %>" class="form-control" style="min-width:160px"></td>
              <td><input type="text" name="guest_phone" value="<%= g.guest_phone || '' %>" class="form-control" style="min-width:120px"></td>
              <td><input type="text" name="event_info" value="<%= g.event_info || '' %>" class="form-control" style="min-width:120px"></td>
              <td style="white-space:nowrap"><button type="submit" class="btn btn-sm btn-primary">Update</button></form>
              <form action="/user/guest-list/delete/<%= g.id %>" method="POST" style="display:inline"><button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Remove guest?')">Delete</button></form></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="card card-body text-center"><p style="color:var(--text-tri)">No guests added yet.</p></div>
      <% } %>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
