<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> User</div>
  <div class="navbar-links">
    <a href="/user" class="nav-link">Home</a>
    <a href="/user/vendors" class="nav-link">Continue Shopping</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <div class="success-overlay">
    <div class="success-header">
      <h2>🎉 THANK YOU</h2>
      <p>Your order has been placed successfully!</p>
    </div>
    <div class="success-body">
      <div style="background:linear-gradient(135deg,var(--primary),var(--secondary));color:#fff;padding:1rem;border-radius:var(--radius-sm);margin-bottom:1.5rem;text-align:center;">
        <span style="font-size:0.9rem;opacity:0.8;">Total Amount</span>
        <div style="font-size:2rem;font-weight:800;">₹<%= totalAmount.toFixed(2) %></div>
      </div>

      <div class="detail-row">
        <span class="detail-label">Name</span>
        <span class="detail-value"><%= orderDetails.name %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Number</span>
        <span class="detail-value"><%= orderDetails.number %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">E-mail</span>
        <span class="detail-value"><%= orderDetails.email %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Payment Method</span>
        <span class="detail-value"><%= orderDetails.payment_method %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Address</span>
        <span class="detail-value"><%= orderDetails.address %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">State</span>
        <span class="detail-value"><%= orderDetails.state %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">City</span>
        <span class="detail-value"><%= orderDetails.city %></span>
      </div>
      <div class="detail-row">
        <span class="detail-label">Pin Code</span>
        <span class="detail-value"><%= orderDetails.pincode %></span>
      </div>

      <a href="/user/vendors" class="btn btn-primary btn-block btn-lg mt-3">Continue Shopping</a>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
