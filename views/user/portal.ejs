<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div class="welcome-banner">
        <h1>Welcome back, <%= user.name %>! 👋</h1>
        <p>Discover great deals and track your orders seamlessly.</p>
      </div>
      <div class="stat-cards">
        <div class="stat-card"><div class="stat-card-icon purple"><span class="material-icons-outlined">shopping_bag</span></div><div><div class="stat-num"><%= orderStats.total %></div><div class="stat-label">Total Orders</div></div></div>
        <div class="stat-card"><div class="stat-card-icon orange"><span class="material-icons-outlined">hourglass_top</span></div><div><div class="stat-num"><%= orderStats.processing %></div><div class="stat-label">Processing</div></div></div>
        <div class="stat-card"><div class="stat-card-icon blue"><span class="material-icons-outlined">local_shipping</span></div><div><div class="stat-num"><%= orderStats.shipped %></div><div class="stat-label">Shipped</div></div></div>
        <div class="stat-card"><div class="stat-card-icon green"><span class="material-icons-outlined">check_circle</span></div><div><div class="stat-num"><%= orderStats.delivered %></div><div class="stat-label">Delivered</div></div></div>
      </div>
      <div class="dashboard-grid">
        <a href="/user/view-products" class="dash-card"><div class="dash-card-icon"><span class="material-icons-outlined">grid_view</span></div><div><h3>Shop Now</h3><p>Browse all products from sellers.</p></div><span class="material-icons-outlined arrow">arrow_forward</span></a>
        <a href="/user/cart" class="dash-card"><div class="dash-card-icon"><span class="material-icons-outlined">shopping_cart</span></div><div><h3>My Cart</h3><p>View items and checkout.</p></div><span class="material-icons-outlined arrow">arrow_forward</span></a>
        <a href="/user/wishlist" class="dash-card"><div class="dash-card-icon"><span class="material-icons-outlined">favorite</span></div><div><h3>Wishlist</h3><p>Items you saved for later.</p></div><span class="material-icons-outlined arrow">arrow_forward</span></a>
        <a href="/user/order-status" class="dash-card"><div class="dash-card-icon"><span class="material-icons-outlined">local_shipping</span></div><div><h3>Track Orders</h3><p>View order status and tracking.</p></div><span class="material-icons-outlined arrow">arrow_forward</span></a>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px">
        <div class="section-card">
          <h3>Recent Orders <a href="/user/order-status">View All</a></h3>
          <% if (recentOrders && recentOrders.length > 0) { %>
            <% recentOrders.forEach(o => { %>
              <div style="display:flex;justify-content:space-between;align-items:center;padding:10px 0;border-bottom:1px solid var(--border-lt)">
                <div><strong style="font-size:13px"><%= o.name || 'Order' %></strong><br><small style="color:var(--text-tri)">Order #<%= o.id %> • ₹<%= o.total_amount ? o.total_amount.toFixed(2) : '0.00' %></small></div>
                <span class="status-badge <%= o.status === 'Delivered' ? 'status-delivered' : o.status === 'Shipped' ? 'status-shipped' : o.status === 'Cancelled' ? 'status-cancelled' : 'status-processing' %>"><%= o.status %></span>
              </div>
            <% }) %>
          <% } else { %>
            <div style="text-align:center;padding:24px 0"><span class="material-icons-outlined" style="font-size:32px;color:var(--text-tri)">shopping_bag</span><p style="color:var(--text-tri);font-size:13px;margin-top:4px">No orders yet. <a href="/user/view-products" style="color:var(--primary)">Start shopping</a></p></div>
          <% } %>
        </div>
        <div class="section-card">
          <h3><span class="material-icons-outlined" style="font-size:18px;color:var(--coral)">favorite</span> Wishlist <a href="/user/wishlist">View All</a></h3>
          <% if (wishlistItems && wishlistItems.length > 0) { %>
            <% wishlistItems.forEach(w => { %>
              <div style="display:flex;align-items:center;gap:12px;padding:8px 0;border-bottom:1px solid var(--border-lt)">
                <div style="width:44px;height:44px;border-radius:8px;overflow:hidden;background:var(--muted)"><img src="/uploads/<%= w.image %>" style="width:100%;height:100%;object-fit:cover" onerror="this.src=''"></div>
                <div style="flex:1;min-width:0"><strong style="font-size:13px;display:block;white-space:nowrap;overflow:hidden;text-overflow:ellipsis"><%= w.name %></strong><span style="font-size:13px;font-weight:700;color:var(--primary)">₹<%= (w.discount_price || w.price).toFixed(2) %></span></div>
              </div>
            <% }) %>
          <% } else { %>
            <div style="text-align:center;padding:24px 0"><span class="material-icons-outlined" style="font-size:32px;color:var(--text-tri)">favorite_border</span><p style="color:var(--text-tri);font-size:13px;margin-top:4px">Your wishlist is empty</p></div>
          <% } %>
        </div>
      </div>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
