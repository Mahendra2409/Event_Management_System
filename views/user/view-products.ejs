<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div class="page-header"><h1>Shop All Products</h1><p>Browse our complete collection</p></div>
      <div class="filter-bar">
        <span class="material-icons-outlined" style="color:var(--text-tri)">search</span>
        <form action="/user/view-products" method="GET" style="display:contents">
          <input type="text" name="search" class="form-control" placeholder="Search products..." value="<%= searchQuery || '' %>" style="flex:1;border:none;box-shadow:none;background:transparent">
          <input type="hidden" name="category" value="<%= selectedCategory %>">
          <input type="hidden" name="sort" value="<%= sortBy %>">
        </form>
        <div style="height:24px;width:1px;background:var(--border)"></div>
        <select class="form-control" style="width:160px" onchange="window.location.href='/user/view-products?category='+this.value+'&sort=<%= sortBy %>'">
          <option value="all" <%= selectedCategory === 'all' ? 'selected' : '' %>>All Categories</option>
          <% if (categories && categories.length) { categories.forEach(c => { %>
            <option value="<%= c.name %>" <%= selectedCategory === c.name ? 'selected' : '' %>><%= c.name %></option>
          <% }) } %>
        </select>
        <select class="form-control" style="width:140px" onchange="window.location.href='/user/view-products?category=<%= selectedCategory %>&sort='+this.value">
          <option value="newest" <%= sortBy === 'newest' ? 'selected' : '' %>>Newest</option>
          <option value="price-low" <%= sortBy === 'price-low' ? 'selected' : '' %>>Price: Low</option>
          <option value="price-high" <%= sortBy === 'price-high' ? 'selected' : '' %>>Price: High</option>
          <option value="rating" <%= sortBy === 'rating' ? 'selected' : '' %>>Top Rated</option>
        </select>
      </div>
      <% if (products && products.length > 0) { %>
      <div class="products-grid" id="productGrid">
        <% products.forEach(p => { %>
        <div class="product-card" data-name="<%= p.name.toLowerCase() %>">
          <div class="product-img">
            <img src="/uploads/<%= p.image %>" alt="<%= p.name %>" onerror="this.style.display='none'">
            <% if (p.discount_price) { %><span class="product-badge sale"><%= Math.round((1 - p.discount_price/p.price) * 100) %>% OFF</span><% } %>
            <form action="/user/wishlist/toggle" method="POST" style="display:inline">
              <input type="hidden" name="product_id" value="<%= p.id %>">
              <button type="submit" class="product-wishlist-btn <%= wishlistIds.includes(p.id) ? 'active' : '' %>">
                <span class="material-icons-outlined"><%= wishlistIds.includes(p.id) ? 'favorite' : 'favorite_border' %></span>
              </button>
            </form>
          </div>
          <div class="product-body">
            <a href="/user/product/<%= p.id %>"><h4><%= p.name %></h4></a>
            <small><%= p.seller_name %><% if (p.category_name) { %> • <%= p.category_name %><% } %></small>
            <% if (p.rating > 0) { %>
              <div class="stars" style="margin-top:4px">
                <% for(let i=1;i<=5;i++){%><span class="material-icons-outlined<%= i > Math.round(p.rating) ? ' empty' : '' %>">star</span><%}%>
                <small style="color:var(--text-tri);margin-left:4px">(<%= p.reviews_count %>)</small>
              </div>
            <% } %>
            <div class="product-footer">
              <span class="product-price">₹<%= (p.discount_price || p.price).toFixed(2) %>
                <% if (p.discount_price) { %><span class="original">₹<%= p.price.toFixed(2) %></span><% } %>
              </span>
              <form action="/user/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= p.id %>"><input type="hidden" name="quantity" value="1"><button type="submit" class="btn btn-sm btn-primary"><span class="material-icons-outlined" style="font-size:14px">add_shopping_cart</span></button></form>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %>
      <div class="card card-body text-center" style="padding:48px">
        <span class="material-icons-outlined" style="font-size:48px;color:var(--text-tri)">inventory_2</span>
        <h3 style="margin:12px 0 4px">No Products Found</h3>
        <p style="color:var(--text-tri)">Try a different search or category.</p>
      </div>
      <% } %>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
