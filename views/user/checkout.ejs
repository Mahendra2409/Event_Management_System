<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="checkout-overlay">
      <div class="checkout-card">
        <div class="checkout-header">
          <div class="checkout-icon"><span class="material-icons-outlined">shopping_bag</span></div>
          <div><h2>Checkout</h2><p>Please fill in your details to complete the order</p></div>
          <a href="/user/cart" class="close-btn"><span class="material-icons-outlined">close</span></a>
        </div>
        <div class="checkout-body">
          <% if (locals.error) { %><div class="alert alert-error"><%= error %></div><% } %>
          <form action="/user/checkout" method="POST" data-validate>
            <div class="grid-2">
              <div class="form-group"><label>Full Name *</label><div class="input-icon-wrap"><span class="material-icons-outlined">person</span><input type="text" name="name" class="form-control" placeholder="John Doe" required data-label="Full Name"></div></div>
              <div class="form-group"><label>Phone Number *</label><div class="input-icon-wrap"><span class="material-icons-outlined">phone</span><input type="text" name="number" class="form-control" placeholder="9876543210" required data-label="Phone Number"></div></div>
            </div>
            <div class="grid-2">
              <div class="form-group"><label>Email Address *</label><div class="input-icon-wrap"><span class="material-icons-outlined">mail</span><input type="email" name="email" class="form-control" placeholder="john@example.com" required data-label="Email"></div></div>
              <div class="form-group"><label>Payment Method *</label><div class="input-icon-wrap"><span class="material-icons-outlined">credit_card</span><select name="payment_method" class="form-control" required data-label="Payment Method" style="padding-left:36px"><option value="">Select Method</option><option value="Credit / Debit Card">Credit / Debit Card</option><option value="UPI">UPI</option><option value="Net Banking">Net Banking</option><option value="Cash on Delivery">Cash on Delivery</option></select></div></div>
            </div>
            <div class="form-group"><label>Address *</label><div class="input-icon-wrap"><span class="material-icons-outlined">location_on</span><input type="text" name="address" class="form-control" placeholder="123, Main Street" required data-label="Address"></div></div>
            <div class="grid-2">
              <div class="form-group"><label>State *</label><input type="text" name="state" class="form-control" placeholder="State" required data-label="State"></div>
              <div class="form-group"><label>City *</label><input type="text" name="city" class="form-control" placeholder="City" required data-label="City"></div>
            </div>
            <div class="grid-2">
              <div class="form-group"><label>ZIP / Pin Code *</label><input type="text" name="pincode" class="form-control" placeholder="10001" required data-label="Pin Code"></div>
              <div class="form-group"><label>Country</label><input type="text" class="form-control" value="India" disabled></div>
            </div>

            <div class="checkout-summary">
              <span class="material-icons-outlined">receipt</span>
              <div><strong>Order Summary</strong><br><small><%= cartItems.length %> Items</small></div>
              <div class="summary-amount">₹<%= totalAmount.toFixed(2) %></div>
            </div>

            <div class="checkout-actions">
              <a href="/user/cart" class="btn btn-outline"><span class="material-icons-outlined" style="font-size:16px">shopping_cart</span> Continue Shopping</a>
              <button type="submit" class="btn btn-primary"><span class="material-icons-outlined" style="font-size:16px">shopping_bag</span> Place Order Securely</button>
            </div>
            <div class="checkout-security"><span class="material-icons-outlined" style="font-size:14px">verified_user</span> Your payment information is secure and encrypted</div>
          </form>
        </div>
      </div>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
