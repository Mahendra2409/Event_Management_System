<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> User</div>
  <div class="navbar-links">
    <a href="/user" class="nav-link">Home</a>
    <a href="/user/cart" class="nav-link">Cart</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <div class="auth-container" style="max-width:600px;">
    <div class="card">
      <div class="card-header">
        <h2>Checkout</h2>
        <p class="auth-subtitle">Total: ₹<%= totalAmount.toFixed(2) %></p>
      </div>
      <div class="card-body">
        <% if (locals.error) { %>
          <div class="alert alert-error"><%= error %></div>
        <% } %>

        <div style="background:var(--bg-muted);padding:1rem;border-radius:var(--radius-sm);margin-bottom:1.5rem;">
          <h4 style="margin-bottom:0.5rem;">Items</h4>
          <% cartItems.forEach(item => { %>
            <div style="display:flex;justify-content:space-between;padding:0.3rem 0;font-size:0.9rem;">
              <span><%= item.name %> × <%= item.quantity %></span>
              <strong>₹<%= (item.price * item.quantity).toFixed(2) %></strong>
            </div>
          <% }) %>
        </div>

        <form action="/user/checkout" method="POST" data-validate>
          <h4 style="margin-bottom:1rem;">Details</h4>
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
            <div class="form-group">
              <label for="name">Name *</label>
              <input type="text" name="name" id="name" class="form-control" placeholder="Full name" required data-label="Name" value="<%= user.name %>">
            </div>
            <div class="form-group">
              <label for="number">Number *</label>
              <input type="tel" name="number" id="number" class="form-control" placeholder="Phone number" required data-label="Number">
            </div>
            <div class="form-group">
              <label for="email">E-mail *</label>
              <input type="email" name="email" id="email" class="form-control" placeholder="Email" required data-label="Email" value="<%= user.email %>">
            </div>
            <div class="form-group">
              <label for="payment_method">Payment Method *</label>
              <select name="payment_method" id="payment_method" class="form-control" required data-label="Payment Method">
                <option value="">Select</option>
                <option value="Cash">Cash</option>
                <option value="UPI">UPI</option>
              </select>
            </div>
            <div class="form-group" style="grid-column:1/-1;">
              <label for="address">Address *</label>
              <input type="text" name="address" id="address" class="form-control" placeholder="Street address" required data-label="Address">
            </div>
            <div class="form-group">
              <label for="state">State *</label>
              <input type="text" name="state" id="state" class="form-control" placeholder="State" required data-label="State">
            </div>
            <div class="form-group">
              <label for="city">City *</label>
              <input type="text" name="city" id="city" class="form-control" placeholder="City" required data-label="City">
            </div>
            <div class="form-group">
              <label for="pincode">Pin Code *</label>
              <input type="text" name="pincode" id="pincode" class="form-control" placeholder="Pin code" required data-label="Pin Code">
            </div>
          </div>
          <button type="submit" class="btn btn-primary btn-block btn-lg mt-2">Order Now</button>
        </form>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
