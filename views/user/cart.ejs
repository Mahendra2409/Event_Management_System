<%- include('../partials/header') %>
<nav class="navbar">
  <div class="navbar-brand"><span>EMS</span> User</div>
  <div class="navbar-links">
    <a href="/user" class="nav-link">Home</a>
    <a href="/user/vendors" class="nav-link">View Product</a>
    <a href="/user/cart" class="nav-link active">Cart</a>
    <a href="/user/order-status" class="nav-link">Product Status</a>
    <a href="/logout" class="nav-link logout">LogOut</a>
  </div>
</nav>
<div class="main-container">
  <% if (locals.success) { %>
    <div class="alert alert-success">✅ <%= success %></div>
  <% } %>
  <% if (locals.error) { %>
    <div class="alert alert-error">⚠️ <%= error %></div>
  <% } %>

  <div class="page-header">
    <h1>Shopping Cart</h1>
  </div>

  <% if (cartItems && cartItems.length > 0) { %>
  <div class="table-container card">
    <table>
      <thead>
        <tr>
          <th>Image</th>
          <th>Name</th>
          <th>Price</th>
          <th>Quantity</th>
          <th>Total Price</th>
          <th>Action</th>
        </tr>
      </thead>
      <tbody>
        <% cartItems.forEach(item => { %>
        <tr>
          <td><img src="/uploads/<%= item.image %>" alt="<%= item.name %>" style="width:50px;height:50px;object-fit:cover;border-radius:6px;" onerror="this.src='data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI1MCIgaGVpZ2h0PSI1MCIgZmlsbD0iI2NjYyI+PHJlY3Qgd2lkdGg9IjUwIiBoZWlnaHQ9IjUwIiBmaWxsPSIjZWVlIi8+PC9zdmc+'"></td>
          <td><strong><%= item.name %></strong><br><small style="color:var(--grey-500);">by <%= item.vendor_name %></small></td>
          <td>₹<%= item.price.toFixed(2) %></td>
          <td>
            <form action="/user/cart/update/<%= item.id %>" method="POST">
              <select name="quantity" class="qty-select" style="padding:0.3rem 0.5rem;border:1px solid var(--grey-300);border-radius:4px;">
                <% for(let i = 1; i <= 10; i++) { %>
                  <option value="<%= i %>" <%= item.quantity === i ? 'selected' : '' %>><%= i %></option>
                <% } %>
              </select>
            </form>
          </td>
          <td><strong>₹<%= item.total_price.toFixed(2) %></strong></td>
          <td>
            <form action="/user/cart/remove/<%= item.id %>" method="POST" style="display:inline;">
              <button type="submit" class="btn btn-sm btn-danger">Remove</button>
            </form>
          </td>
        </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="cart-summary">
    <div>
      <span style="font-size:0.9rem;opacity:0.8;">Grand Total</span>
      <div class="grand-total">₹<%= grandTotal.toFixed(2) %></div>
    </div>
    <div class="cart-actions">
      <form action="/user/cart/clear" method="POST" style="display:inline;">
        <button type="submit" class="btn btn-danger" onclick="return confirm('Remove all items?')">Delete All</button>
      </form>
      <a href="/user/checkout" class="btn btn-success btn-lg">Proceed to CheckOut</a>
    </div>
  </div>

  <% } else { %>
  <div class="card card-body text-center">
    <p style="color:var(--grey-600);margin-bottom:1rem;">Your cart is empty.</p>
    <a href="/user/vendors" class="btn btn-primary">Browse Vendors</a>
  </div>
  <% } %>
</div>
<%- include('../partials/footer') %>
