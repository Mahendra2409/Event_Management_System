<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header"><h1>Delivery Tracking</h1><p>Track your ordered items</p></div>
      <% if (items && items.length > 0) { %>
      <div class="table-container"><table><thead><tr><th>Product</th><th>Item</th><th>Qty</th><th>Price</th><th>Status</th><th>Seller</th></tr></thead><tbody>
        <% items.forEach(item => { %>
        <tr>
          <td><div style="width:48px;height:48px;border-radius:8px;overflow:hidden;background:var(--muted)"><img src="/uploads/<%= item.image %>" style="width:100%;height:100%;object-fit:cover" onerror="this.src=''"></div></td>
          <td><strong><%= item.product_name %></strong></td>
          <td><%= item.quantity %></td>
          <td>₹<%= (item.price * item.quantity).toFixed(2) %></td>
          <td><span class="status-badge <%= item.status === 'Delivered' ? 'status-delivered' : item.status === 'Shipped' ? 'status-shipped' : item.status === 'Cancelled' ? 'status-cancelled' : 'status-processing' %>"><%= item.status %></span></td>
          <td><%= item.seller_name %></td>
        </tr>
        <% }) %>
      </tbody></table></div>
      <% } else { %><div class="card card-body text-center" style="padding:48px"><span class="material-icons-outlined" style="font-size:48px;color:var(--text-tri)">inventory</span><h3 style="margin:12px 0">No items to track</h3></div><% } %>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
