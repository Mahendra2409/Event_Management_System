<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <div class="page-header"><h1>Product Status</h1><p>Track the delivery status of your ordered products</p></div>

      <% if (items && items.length > 0) { %>
      <div class="table-container">
        <table>
          <thead><tr><th>Product</th><th>Vendor</th><th>Qty</th><th>Price</th><th>Status</th><th>Order Date</th></tr></thead>
          <tbody>
          <% items.forEach(item => { %>
            <tr>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  <div style="width:40px;height:40px;border-radius:8px;overflow:hidden;background:var(--muted)"><img src="/uploads/<%= item.image %>" style="width:100%;height:100%;object-fit:cover" onerror="this.src=''"></div>
                  <strong><%= item.product_name %></strong>
                </div>
              </td>
              <td><%= item.vendor_name %></td>
              <td><%= item.quantity %></td>
              <td>₹<%= (item.price * item.quantity).toFixed(2) %></td>
              <td><span class="status-badge <%= item.status === 'Out For Delivery' ? 'status-delivered' : item.status === 'Ready for Shipping' ? 'status-shipped' : item.status === 'Cancelled' ? 'status-cancelled' : 'status-pending' %>"><%= item.status %></span></td>
              <td><%= new Date(item.order_date).toLocaleDateString() %></td>
            </tr>
          <% }) %>
          </tbody>
        </table>
      </div>
      <% } else { %>
      <div class="card card-body text-center" style="padding:48px">
        <span class="material-icons-outlined" style="font-size:48px;color:var(--text-tri)">inventory</span>
        <h3 style="margin:12px 0 4px">No Products Ordered</h3>
        <p style="color:var(--text-tri)">You haven't ordered any products yet. <a href="/user/vendors" style="color:var(--primary)">Browse vendors</a> to get started.</p>
      </div>
      <% } %>
    </div>
    <div class="app-footer">© 2025 Event Management System. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
