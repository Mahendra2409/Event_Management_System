<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px">
        <div class="page-header" style="margin-bottom:0"><h1><%= seller.name %>'s Products</h1><p><%= seller.category %></p></div>
        <a href="/user/shops" class="btn btn-outline"><span class="material-icons-outlined" style="font-size:16px">arrow_back</span> All Sellers</a>
      </div>
      <% if (products && products.length > 0) { %>
      <div class="products-grid">
        <% products.forEach(p => { %>
        <div class="product-card">
          <div class="product-img">
            <img src="/uploads/<%= p.image %>" alt="<%= p.name %>" onerror="this.style.display='none'">
            <% if (p.discount_price) { %><span class="product-badge sale"><%= Math.round((1 - p.discount_price/p.price) * 100) %>% OFF</span><% } %>
            <form action="/user/wishlist/toggle" method="POST" style="display:inline"><input type="hidden" name="product_id" value="<%= p.id %>"><button type="submit" class="product-wishlist-btn <%= wishlistIds.includes(p.id) ? 'active' : '' %>"><span class="material-icons-outlined"><%= wishlistIds.includes(p.id) ? 'favorite' : 'favorite_border' %></span></button></form>
          </div>
          <div class="product-body">
            <a href="/user/product/<%= p.id %>"><h4><%= p.name %></h4></a>
            <small><%= p.category_name || seller.category %></small>
            <div class="product-footer">
              <span class="product-price">₹<%= (p.discount_price || p.price).toFixed(2) %><% if (p.discount_price) { %><span class="original">₹<%= p.price.toFixed(2) %></span><% } %></span>
              <form action="/user/cart/add" method="POST"><input type="hidden" name="product_id" value="<%= p.id %>"><input type="hidden" name="quantity" value="1"><button type="submit" class="btn btn-sm btn-primary"><span class="material-icons-outlined" style="font-size:14px">add_shopping_cart</span></button></form>
            </div>
          </div>
        </div>
        <% }) %>
      </div>
      <% } else { %><div class="card card-body text-center" style="padding:48px"><span class="material-icons-outlined" style="font-size:48px;color:var(--text-tri)">inventory_2</span><h3 style="margin:12px 0">No products yet</h3></div><% } %>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
