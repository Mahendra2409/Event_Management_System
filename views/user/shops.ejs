<%- include('../partials/header') %>
<div class="app-layout">
  <%- include('../partials/sidebar-user') %>
  <div class="main-area">
    <%- include('../partials/topbar') %>
    <div class="content">
      <% if (locals.success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div class="page-header"><h1>Sellers</h1><p>Browse trusted sellers on NexCart</p></div>
      <div class="category-pills">
        <a href="/user/shops" class="category-pill <%= selectedCategory === 'all' ? 'active' : '' %>">All</a>
        <% categories.forEach(c => { %><a href="/user/shops?category=<%= c %>" class="category-pill <%= selectedCategory === c ? 'active' : '' %>"><%= c %></a><% }) %>
      </div>
      <% if (sellers && sellers.length > 0) { %>
      <div class="dashboard-grid">
        <% sellers.forEach(s => { %>
        <a href="/user/shops/<%= s.id %>/products" class="dash-card">
          <div class="dash-card-icon" style="width:52px;height:52px;font-size:22px;font-weight:700;border-radius:50%"><%= s.name.charAt(0).toUpperCase() %></div>
          <div><h3><%= s.name %></h3><p><%= s.category %> • <%= s.productCount || 0 %> products</p></div>
          <span class="material-icons-outlined arrow">arrow_forward</span>
        </a>
        <% }) %>
      </div>
      <% } else { %><div class="card card-body text-center" style="padding:48px"><span class="material-icons-outlined" style="font-size:48px;color:var(--text-tri)">storefront</span><h3 style="margin:12px 0 4px">No sellers found</h3></div><% } %>
    </div>
    <div class="app-footer">© 2025 NexCart. All rights reserved.</div>
  </div>
</div>
<%- include('../partials/footer') %>
